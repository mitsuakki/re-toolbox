{
  "mcpServers": {
    "radare2": {
      "command": "docker",
      "args": ["exec", "-i", "ctf-re", "r2pm", "-r", "r2mcp"]
    },
    "ghidra-headless": {
      "command": "docker",
      "args": [
        "exec", "-i", "ctf-re",
        "python3", "/opt/tools/ghidra-mcp/bridge_mcp_ghidra.py",
        "--ghidra-server", "http://127.0.0.1:8089/"
      ]
    },
    "shell": {
      "command": "docker",
      "args": [
        "exec", "-i", "ctf-re",
        "python3", "/opt/tools/scripts/mcp/shell-mcp.py"
      ]
    },
    "python": {
      "command": "docker",
      "args": [
        "exec", "-i", "ctf-re",
        "python3", "/opt/tools/scripts/mcp/python-mcp.py"
      ]
    },
    "fuzz": {
      "command": "docker",
      "args": [
        "exec", "-i", "ctf-re",
        "python3", "/opt/tools/scripts/mcp/fuzz-mcp.py"
      ]
    },
    "angr": {
      "command": "docker",
      "args": [
        "exec", "-i", "ctf-re",
        "python3", "/opt/tools/scripts/mcp/angr-mcp.py"
      ]
    }
  }
}
